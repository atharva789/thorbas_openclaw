# Secrets — never send to Docker daemon
.env
config/client_secret.json
config/omniclaw-tokens.json

# Git
.git

# Docs and plans (not needed in image)
docs/
README.md

# OS
.DS_Store
Thumbs.db

# Exclude node_modules everywhere EXCEPT the pre-built plugin
# (needed so Docker COPY can include it without rebuilding on VPS)
node_modules
scraper/.venv
scraper/__pycache__
!local-config/extensions/omniclaw/node_modules
