{
  "gateway": {
    "bind": "lan"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "google/gemini-2.5-flash"
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing"
    }
  },
  "plugins": {
    "entries": {
      "omniclaw": {
        "enabled": true,
        "config": {
          "client_secret_path": "/home/node/.openclaw/client_secret.json",
          "tokens_path": "/home/node/.openclaw/omniclaw-tokens.json",
          "oauth_port": 9753
        }
      }
    }
  }
}
